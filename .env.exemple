# Nom de l'application
APP_NAME=dolitest

# MySQL
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=dolibarr

# Dolibarr — DOLI_DB_NAME doit être identique à MYSQL_DATABASE
DOLI_DB_NAME=dolibarr
DOLI_DB_USER=root
DOLI_DB_PASSWORD=root

# Premier utilisateur (installation initiale uniquement)
DOLI_ADMIN_LOGIN=admin
DOLI_ADMIN_PASSWORD=admin

# Permissions fichiers (id -u / id -g sur l'hôte)
WWW_USER_ID=1000
WWW_GROUP_ID=1000

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin 

